# Dockhand MCP Server Configuration

# Dockhand Server URL (required)
DOCKHAND_URL=https://dock.strausmann.cloud

# Authentication — choose ONE:
#
# Option A (recommended): Personal API token. Create at /profile in
# Dockhand UI. Bypasses MFA; revocable per-token.
# DOCKHAND_API_TOKEN=dh_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option B (legacy): Username + password. Incompatible with MFA-protected
# accounts since this MCP doesn't implement TOTP.
DOCKHAND_USERNAME=ClaudeCode
DOCKHAND_PASSWORD=CHANGE_ME

# MCP Server Port (optional, default: 8080)
MCP_PORT=8080

# Log Level (optional, default: info)
LOG_LEVEL=info
