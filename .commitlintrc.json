{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "containers",
        "stacks",
        "images",
        "networks",
        "volumes",
        "environments",
        "git-stacks",
        "users",
        "system",
        "auth",
        "audit",
        "notifications",
        "registries",
        "schedules",
        "client",
        "tests",
        "ci",
        "deps",
        "docs",
        "security",
        "api",
        "tools",
        "review",
        "release"
      ]
    ],
    "scope-empty": [2, "never"],
    "subject-empty": [2, "never"],
    "type-empty": [2, "never"]
  }
}
